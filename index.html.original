// Loading Screen
function updateLoading(progress, text) {
    const bar = document.getElementById('loading-progress');
    const txt = document.getElementById('loading-text');
    if (bar) bar.style.width = progress + '%';
    if (txt) txt.textContent = text;
}

function hideLoading() {
    const screen = document.getElementById('loading-screen');
    if (screen) {
        screen.classList.add('hidden');
        setTimeout(() => screen.style.display = 'none', 800);
    }
}

// Toast Notifications
function showToast(message, type = 'info') {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast';
    
    const icons = { info: '??', success: '?', warning: '??', error: '?' };
    toast.innerHTML = `${icons[type] || '??'} ${message}`;
    
    container.appendChild(toast);
    
    setTimeout(() => toast.classList.add('show'), 10);
    setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 400);
    }, 3000);
}

// Theme Toggle
function toggleTheme() {
    currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
    document.body.setAttribute('data-theme', currentTheme);
    showToast(`Switched to ${currentTheme} theme`, 'info');
}

// Floating Action Menu
function toggleFabMenu() {
    const menu = document.getElementById('fab-menu');
    const btn = document.getElementById('fab-toggle');
    menu.classList.toggle('open');
    btn.style.transform = menu.classList.contains('open') ? 'rotate(45deg)' : 'rotate(0deg)';
}

// Particle System for Block Effects
function createParticleExplosion(position, color = 0x00d4ff, count = 20) {
    const particleGeo = new THREE.BoxGeometry(0.05, 0.05, 0.05);
    const particleMat = new THREE.MeshBasicMaterial({ color: color });
    
    for (let i = 0; i < count; i++) {
        const particle = new THREE.Mesh(particleGeo, particleMat.clone());
        particle.position.copy(position);
        particle.position.x += (Math.random() - 0.5) * 0.5;
        particle.position.y += (Math.random() - 0.5) * 0.5;
        particle.position.z += (Math.random() - 0.5) * 0.5;
        
        particle.userData = {
            velocity: new THREE.Vector3(
                (Math.random() - 0.5) * 0.2,
                Math.random() * 0.3,
                (Math.random() - 0.5) * 0.2
            ),
            life: 1.0,
            decay: 0.02 + Math.random() * 0.02
        };
        
        scene.add(particle);
        particles.push(particle);
    }
}

function updateParticles() {
    for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.position.add(p.userData.velocity);
        p.userData.velocity.y -= 0.01; // Gravity
        p.userData.life -= p.userData.decay;
        p.material.opacity = p.userData.life;
        p.material.transparent = true;
        p.rotation.x += 0.1;
        p.rotation.y += 0.1;
        
        if (p.userData.life <= 0 || p.position.y < -5) {
            scene.remove(p);
            particles.splice(i, 1);
        }
    }
}

// Block Placement Animation
function animateBlockPlacement(block) {
    const targetScale = block.scale.clone();
    block.scale.set(0.01, 0.01, 0.01);
    
    let progress = 0;
    const duration = 20; // frames
    
    function animate() {
        progress++;
        const t = progress / duration;
        const ease = 1 - Math.pow(1 - t, 3); // Ease out cubic
        
        block.scale.lerpVectors(new THREE.Vector3(0.01, 0.01, 0.01), targetScale, ease);
        
        if (progress < duration) {
            requestAnimationFrame(animate);
        } else {
            block.scale.copy(targetScale);
        }
    }
    animate();
}

// Weather System
function toggleWeather() {
    weatherEnabled = !weatherEnabled;
    document.getElementById('weather-btn').classList.toggle('active', weatherEnabled);
    
    if (!weatherEnabled) {
        // Clear weather particles
        weatherParticles.forEach(p => scene.remove(p));
        weatherParticles = [];
        showToast('Weather disabled', 'info');
    } else {
        showToast(`${weatherType === 'rain' ? '??? Rain' : '?? Snow'} enabled`, 'info');
    }
}

function updateWeather() {
    if (!weatherEnabled) return;
    
    // Spawn new particles
    if (weatherParticles.length < 1000) {
        const geo = weatherType === 'rain' 
            ? new THREE.BoxGeometry(0.02, 0.2, 0.02)
            : new THREE.SphereGeometry(0.05, 4, 4);
        const mat = new THREE.MeshBasicMaterial({ 
            color: weatherType === 'rain' ? 0x88ccff : 0xffffff,
            transparent: true,
            opacity: 0.6
        });
        
        const particle = new THREE.Mesh(geo, mat);
        particle.position.set(
            (Math.random() - 0.5) * 60,
            30 + Math.random() * 10,
            (Math.random() - 0.5) * 60
        );
        particle.userData = {
            velocity: weatherType === 'rain' 
                ? new THREE.Vector3(0, -0.5 - Math.random() * 0.3, 0)
                : new THREE.Vector3((Math.random() - 0.5) * 0.1, -0.1 - Math.random() * 0.1, (Math.random() - 0.5) * 0.1)
        };
        
        scene.add(particle);
        weatherParticles.push(particle);
    }
    
    // Update particles
    for (let i = weatherParticles.length - 1; i >= 0; i--) {
        const p = weatherParticles[i];
        p.position.add(p.userData.velocity);
        
        if (p.position.y < 0) {
            scene.remove(p);
            weatherParticles.splice(i, 1);
        }
    }
}

// Auto Rotate Camera
function toggleAutoRotate() {
    autoRotate = !autoRotate;
    document.getElementById('rotate-btn').classList.toggle('active', autoRotate);
    showToast(autoRotate ? '?? Auto-rotate enabled' : '?? Auto-rotate disabled', 'info');
}

// Day/Night Cycle
function setTimeOfDay(hour) {
    timeOfDay = parseFloat(hour);
    
    // Calculate sun position and colors based on hour
    const angle = (timeOfDay / 24) * Math.PI * 2 - Math.PI / 2;
    const radius = 50;
    
    sunLight.position.x = Math.cos(angle) * radius;
    sunLight.position.y = Math.sin(angle) * radius;
    sunLight.position.z = 20;
    
    // Adjust colors based on time
    let skyColor, sunColor, sunIntensity;
    
    if (timeOfDay < 5 || timeOfDay > 20) {
        // Night
        skyColor = 0x0a0a1a;
        sunColor = 0x4444aa;
        sunIntensity = 0.1;
        ambientLight.intensity = 0.2;
    } else if (timeOfDay < 7 || timeOfDay > 18) {
        // Dawn/Dusk
        skyColor = 0xff6b35;
        sunColor = 0xff8844;
        sunIntensity = 0.8;
        ambientLight.intensity = 0.4;
    } else {
        // Day
        skyColor = 0x87CEEB;
        sunColor = 0xfff4e0;
        sunIntensity = 1.2;
        ambientLight.intensity = 0.6;
    }
    
    scene.background.setHex(skyColor);
    scene.fog.color.setHex(skyColor);
    sunLight.color.setHex(sunColor);
    sunLight.intensity = sunIntensity;
}

// Screenshot Feature
function takeScreenshot() {
    renderer.render(scene, camera);
    const dataURL = renderer.domElement.toDataURL('image/png');
    
    const link = document.createElement('a');
    link.download = `BrickForge_Build_${new Date().toISOString().slice(0,19).replace(/:/g,'-')}.png`;
    link.href = dataURL;
    link.click();
    
    showToast('?? Screenshot saved!', 'success');
}

// Save/Load Build
function exportBuild() {
    if (blocks.length === 0) {
        showToast('Nothing to save! Build something first.', 'warning');
        return;
    }
    
    const buildData = {
        version: '1.0',
        timestamp: new Date().toISOString(),
        blocks: blocks.map(serializeBlock)
    };
    
    const blob = new Blob([JSON.stringify(buildData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    
    const link = document.createElement('a');
    link.download = `BrickForge_Build_${Date.now()}.json`;
    link.href = url;
    link.click();
    
    URL.revokeObjectURL(url);
    showToast(`?? Saved ${blocks.length} blocks!`, 'success');
}

function importBuild(input) {
    const file = input.files[0];
    if (!file) return;
    
    const reader = new FileReader();
    reader.onload = (e) => {
        try {
            const data = JSON.parse(e.target.result);
            
            if (!data.blocks || !Array.isArray(data.blocks)) {
                throw new Error('Invalid build file');
            }
            
            // Clear current build
            blocks.forEach(b => scene.remove(b));
            blocks = [];
            
            // Load new blocks
            data.blocks.forEach(blockData => {
                const block = deserializeBlock(blockData);
                if (blockData.color) {
                    block.traverse(child => {
                        if (child.isMesh && child.material) {
                            child.material = child.material.clone();
                            child.material.color.setHex(blockData.color);
                        }
                    });
                }
                scene.add(block);
                blocks.push(block);
            });
            
            saveState();
            updateCount();
            showToast(`?? Loaded ${data.blocks.length} blocks!`, 'success');
        } catch (err) {
            showToast('Error loading file: ' + err.message, 'error');
        }
    };
    reader.readAsText(file);
    input.value = ''; // Reset input
}

// Enhanced animate function
function animateWithEffects() {
    requestAnimationFrame(animateWithEffects);
    
    // Auto-rotate
    if (autoRotate) {
        cameraSpherical.theta += autoRotateSpeed;
        updateCameraFromSpherical();
    }
    
    // Update particles
    updateParticles();
    updateWeather();
    
    // Smooth ghost block hover animation
    if (ghostBlock && ghostBlock.visible) {
        const time = Date.now() * 0.003;
        const baseY = ghostBlock.userData.baseY || ghostBlock.position.y;
        ghostBlock.userData.baseY = baseY;
        ghostBlock.position.y = baseY + Math.sin(time) * 0.03;
    }
    
    // Animate selection box
    if (selectionBox && selectionBox.visible) {
        const time = Date.now() * 0.005;
        selectionBox.rotation.y += 0.01;
    }
    
    renderer.render(scene, camera);
}

// ==================== 3D MODEL IMPORT ====================

let importedModels = [];

function import3DModel(file) {
    const extension = file.name.split('.').pop().toLowerCase();
    const url = URL.createObjectURL(file);
    
    showToast(`Loading ${extension.toUpperCase()} model...`, 'info');
    
    if (extension === 'gltf' || extension === 'glb') {
        const loader = new THREE.GLTFLoader();
        loader.load(url, (gltf) => {
            const model = gltf.scene;
            setupImportedModel(model, file.name);
            URL.revokeObjectURL(url);
        }, undefined, (error) => {
            showToast('Error loading model: ' + error.message, 'error');
            URL.revokeObjectURL(url);
        });
    } else if (extension === 'obj') {
        const loader = new THREE.OBJLoader();
        loader.load(url, (obj) => {
            setupImportedModel(obj, file.name);
            URL.revokeObjectURL(url);
        }, undefined, (error) => {
            showToast('Error loading model: ' + error.message, 'error');
            URL.revokeObjectURL(url);
        });
    } else {
        showToast('Unsupported format. Use .glb, .gltf, or .obj', 'error');
        URL.revokeObjectURL(url);
    }
}

function setupImportedModel(model, name) {
    // Center and scale the model
    const box = new THREE.Box3().setFromObject(model);
    const center = box.getCenter(new THREE.Vector3());
    const size = box.getSize(new THREE.Vector3());
    
    model.position.sub(center);
    const maxDim = Math.max(size.x, size.y, size.z);
    const scale = 5 / maxDim;
    model.scale.setScalar(scale);
    model.position.y += size.y * scale / 2;
    
    // Enable shadows
    model.traverse((child) => {
        if (child.isMesh) {
            child.castShadow = true;
            child.receiveShadow = true;
        }
    });
    
    model.userData = { 
        type: 'imported', 
        deletable: true, 
        name: name,
        isModel: true 
    };
    
    // Place at ghost position or center
    if (ghostBlock && ghostBlock.visible) {
        model.position.copy(ghostBlock.position);
    }
    
    scene.add(model);
    importedModels.push(model);
    blocks.push(model);
    
    // Animation
    animateBlockPlacement(model);
    createParticleExplosion(model.position.clone().add(new THREE.Vector3(0, 1, 0)), 0x00ff88, 30);
    
    saveState();
    updateCount();
    showToast(`? Imported "${name}"`, 'success');
}

// Enhanced lighting with HDR-like effects
function setupEnhancedLighting() {
    // Rim light for better 3D perception
    const rimLight = new THREE.DirectionalLight(0x88ccff, 0.5);
    rimLight.position.set(-30, 20, -30);
    scene.add(rimLight);
    
    // Hemisphere light for natural ambient
    const hemiLight = new THREE.HemisphereLight(0x87CEEB, 0x362d1d, 0.3);
    scene.add(hemiLight);
}

// Call enhanced lighting setup
setupEnhancedLighting();

