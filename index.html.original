            <div class="assignment-meta-item">?? Posted: ${new Date(assignment.createdAt).toLocaleString()}</div>
        </div>
    `;
}

// ==================== REMOTE CURSORS ====================

function updateRemoteCursor(data) {
    let cursor = remoteCursors.get(data.userId);
    
    if (!cursor) {
        cursor = createRemoteCursor(data.color, data.name);
        remoteCursors.set(data.userId, cursor);
        scene.add(cursor);
    }
    
    cursor.position.set(data.position.x, data.position.y, data.position.z);
}

function createRemoteCursor(color, name) {
    const group = new THREE.Group();
    
    // Cursor mesh
    const geometry = new THREE.ConeGeometry(0.1, 0.3, 8);
    const material = new THREE.MeshBasicMaterial({ color: color });
    const cone = new THREE.Mesh(geometry, material);
    cone.rotation.x = Math.PI;
    group.add(cone);
    
    // Name label (simplified as a small sphere for now)
    const labelGeo = new THREE.SphereGeometry(0.05);
    const labelMat = new THREE.MeshBasicMaterial({ color: color });
    const label = new THREE.Mesh(labelGeo, labelMat);
    label.position.y = 0.3;
    group.add(label);
    
    return group;
}

// Send cursor position periodically
setInterval(() => {
    if (currentRoomId && ws && ws.readyState === WebSocket.OPEN && ghostBlock) {
        ws.send(JSON.stringify({
            type: 'cursorMove',
            position: {
                x: ghostBlock.position.x,
                y: ghostBlock.position.y,
                z: ghostBlock.position.z
            }
        }));
    }
}, 100);

// ==================== ENVIRONMENT & BLUEPRINT SYSTEM ====================

function setEnvironment(envName) {
    const env = ENVIRONMENTS[envName];
    if (!env) return;
    
    currentEnvironment = envName;
    
    // Update scene
    scene.background.setHex(env.skyColor);
    scene.fog.color.setHex(env.fogColor);
    scene.fog.density = env.fogDensity;
    scene.fog.near = env.fogNear;
    scene.fog.far = env.fogFar;
    
    // Update ground
    if (ground) {
        ground.material.color.setHex(env.groundColor);
    }
    
    // Update sun
    sunLight.color.setHex(env.sunColor);
    sunLight.intensity = env.sunIntensity;
    ambientLight.intensity = env.ambientIntensity;
    
    // Update UI
    document.querySelectorAll('.env-option').forEach(el => {
        el.classList.toggle('active', el.dataset.env === envName);
    });
    
    showToast(`${env.icon} Environment changed to ${env.name}`, 'success');
    
    // Apply gravity effect (visual feedback)
    applyGravityEffect(env.gravity);
}

function applyGravityEffect(gravity) {
    // Visual feedback based on gravity
    const gravityFactor = gravity / 9.8;
    
    // Adjust fog density based on gravity (lighter gravity = thinner atmosphere)
    const fogAdj = Math.max(0.005, scene.fog.density * gravityFactor);
    scene.fog.density = fogAdj;
    
    // Update particle gravity if applicable
    if (weatherEnabled && weatherType === 'snow') {
        // On low gravity (moon/mars), snow falls slower
        weatherParticles.forEach(p => {
            p.userData.velocity.y = -0.1 * gravityFactor;
        });
    }
}

function toggleEnvironmentPanel() {
    const panel = document.getElementById('environment-panel');
    panel.classList.toggle('active');
}

function toggleBlueprint() {
    blueprintMode = !blueprintMode;
    document.body.classList.toggle('blueprint-mode', blueprintMode);
    
    const btn1 = document.getElementById('blueprint-btn');
    const btn2 = document.getElementById('demo-blueprint-btn');
    
    if (btn1) btn1.textContent = blueprintMode ? '?? Exit Blueprint' : '?? Blueprint';
    if (btn2) btn2.textContent = blueprintMode ? '?? Exit Blueprint' : '?? Blueprint';
    
    showToast(blueprintMode ? '?? Blueprint mode enabled' : '?? Blueprint mode disabled', 'info');
}

// ==================== DEMO MODE ====================

function enterDemoMode() {
    demoMode = true;
    
    // Hide lobby
    document.getElementById('lobby-screen').classList.remove('active');
    
    // Show demo UI
    document.getElementById('demo-indicator').classList.add('active');
    document.getElementById('demo-controls').style.display = 'flex';
    document.getElementById('blueprint-toggle').style.display = 'block';
    document.getElementById('environment-panel').classList.add('active');
    document.getElementById('chat-container').style.display = 'none'; // No chat in demo
    
    // Initialize scene
    initColorPalette();
    createGhostBlock();
    createSelectionBox();
    resetCamera();
    saveState();
    
    // Set default environment
    setEnvironment('earth');
    
    showToast('?? Demo Mode - Build freely and test environments!', 'success');
}

function saveDemoProject() {
    if (blocks.length === 0) {
        showToast('Nothing to save! Build something first.', 'warning');
        return;
    }
    
    const demoData = {
        version: '1.0-demo',
        timestamp: new Date().toISOString(),
        environment: currentEnvironment,
        blocks: blocks.map(b => ({
            type: b.userData.type,
            size: b.userData.size,
            position: { x: b.position.x, y: b.position.y, z: b.position.z },
            rotation: b.rotation.y,
            color: b.userData.color || currentColor
        }))
    };
    
    const blob = new Blob([JSON.stringify(demoData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    
    const link = document.createElement('a');
    link.download = `DemoProject_${currentEnvironment}_${Date.now()}.json`;
    link.href = url;
    link.click();
    
    URL.revokeObjectURL(url);
    showToast('?? Demo project saved! You can import this into a classroom room.', 'success');
}

function loadDemoProject(data) {
    if (!data || !data.blocks) return;
    
    // Set environment
    if (data.environment) {
        setEnvironment(data.environment);
    }
    
    // Load blocks
    data.blocks.forEach(blockData => {
        const block = createRealisticBlock(blockData.type, blockData.size, blockData.color, blockData.rotation);
        block.position.set(blockData.position.x, blockData.position.y, blockData.position.z);
        block.rotation.y = blockData.rotation;
        scene.add(block);
        blocks.push(block);
    });
    
    updateCount();
    saveState();
}

// Update joinApp to show demo panel for teachers
// Update backToLobby to handle demo mode
// Handle demo mode in backToLobby
const originalBackToLobbyFunc = backToLobby;
backToLobby = function() {
    if (demoMode) {
        // Clear demo scene
        blocks.forEach(b => scene.remove(b));
        blocks = [];
        updateCount();
        
        // Reset demo mode
        demoMode = false;
        blueprintMode = false;
        document.body.classList.remove('blueprint-mode');
        
        // Hide demo UI
        document.getElementById('demo-indicator').classList.remove('active');
        document.getElementById('demo-controls').style.display = 'none';
        document.getElementById('blueprint-toggle').style.display = 'none';
        document.getElementById('environment-panel').classList.remove('active');
        
        // Show lobby
        document.getElementById('lobby-screen').classList.add('active');
        
        // Reset environment
        setEnvironment('earth');
    } else {
        originalBackToLobbyFunc();
    }
};

// ==================== EXTENDED BLOCK TYPES ====================

// Update createRealisticBlock to include new block types
const originalCreateBlock = createRealisticBlock;
createRealisticBlock = function(type, size, color, rotation = 0) {
    const group = new THREE.Group();
    
    switch(type) {
        // Sand blocks
        case 'sand-block':
            const sandBlock = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.sand
            );
            sandBlock.position.y = size / 2;
            sandBlock.castShadow = true;
            sandBlock.receiveShadow = true;
            group.add(sandBlock);
            break;
            
        case 'sandstone-brick':
            const ssBlock = new THREE.Mesh(
                new THREE.BoxGeometry(size, size * 0.5, size),
                materials.sandstone
            );
            ssBlock.position.y = size * 0.25;
            ssBlock.castShadow = true;
            ssBlock.receiveShadow = true;
            group.add(ssBlock);
            
            // Add texture lines
            for (let i = 0; i < 3; i++) {
                const line = new THREE.Mesh(
                    new THREE.BoxGeometry(size * 0.9, 0.02, size * 0.9),
                    new THREE.MeshStandardMaterial({ color: 0xb8956a })
                );
                line.position.y = size * 0.1 * (i + 1);
                group.add(line);
            }
            break;
            
        case 'dirt':
            const dirt = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.dirt
            );
            dirt.position.y = size / 2;
            dirt.castShadow = true;
            dirt.receiveShadow = true;
            group.add(dirt);
            
            // Grass on top
            const grass = new THREE.Mesh(
                new THREE.BoxGeometry(size * 0.95, 0.1 * size, size * 0.95),
                materials.leaf
            );
            grass.position.y = size + 0.05 * size;
            group.add(grass);
            break;
            
        case 'clay':
            const clay = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.clay
            );
            clay.position.y = size / 2;
            clay.castShadow = true;
            clay.receiveShadow = true;
            group.add(clay);
            break;
            
        // Concrete blocks
        case 'concrete':
            const concrete = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.concrete
            );
            concrete.position.y = size / 2;
            concrete.castShadow = true;
            concrete.receiveShadow = true;
            group.add(concrete);
            
            // Rebar corners
            const rebarGeo = new THREE.CylinderGeometry(0.05 * size, 0.05 * size, size, 8);
            const positions = [
                [-0.4, -0.4], [0.4, -0.4], [0.4, 0.4], [-0.4, 0.4]
            ];
            positions.forEach(([x, z]) => {
                const rebar = new THREE.Mesh(rebarGeo, materials.rebar);
                rebar.position.set(x * size, size / 2, z * size);
                group.add(rebar);
            });
            break;
            
        case 'concrete-slab':
            const slab = new THREE.Mesh(
                new THREE.BoxGeometry(size, size * 0.2, size),
                materials.concreteSmooth
            );
            slab.position.y = size * 0.1;
            slab.castShadow = true;
            slab.receiveShadow = true;
            group.add(slab);
            break;
            
        // Metal blocks
        case 'steel-beam':
            const beamGeo = new THREE.BoxGeometry(size * 0.3, size * 2, size * 0.3);
            const beam = new THREE.Mesh(beamGeo, materials.steel);
            beam.position.y = size;
            beam.castShadow = true;
            group.add(beam);
            
            // Flanges
            const flangeGeo = new THREE.BoxGeometry(size * 0.5, size * 0.1, size * 0.3);
            const topFlange = new THREE.Mesh(flangeGeo, materials.steel);
            topFlange.position.y = size * 2;
            group.add(topFlange);
            
            const bottomFlange = new THREE.Mesh(flangeGeo, materials.steel);
            bottomFlange.position.y = size * 0.1;
            group.add(bottomFlange);
            break;
            
        case 'metal-plate':
            const plate = new THREE.Mesh(
                new THREE.BoxGeometry(size, 0.05 * size, size),
                materials.iron
            );
            plate.position.y = 0.025 * size;
            plate.castShadow = true;
            plate.receiveShadow = true;
            
            // Rivets
            for (let i = 0; i < 4; i++) {
                const rivet = new THREE.Mesh(
                    new THREE.CylinderGeometry(0.03 * size, 0.03 * size, 0.08 * size, 8),
                    materials.steel
                );
                const angle = (i / 4) * Math.PI * 2;
                rivet.position.set(
                    Math.cos(angle) * 0.4 * size,
                    0.04 * size,
                    Math.sin(angle) * 0.4 * size
                );
                group.add(rivet);
            }
            group.add(plate);
            break;
            
        // Ice and snow
        case 'ice-block':
            const ice = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.ice
            );
            ice.position.y = size / 2;
            group.add(ice);
            break;
            
        case 'snow-block':
            const snow = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.snow
            );
            snow.position.y = size / 2;
            snow.castShadow = true;
            group.add(snow);
            break;
            
        // Magma and special
        case 'magma':
            const magma = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.magma
            );
            magma.position.y = size / 2;
            
            // Add glow light
            const magmaLight = new THREE.PointLight(0xff4500, 1, 5 * size);
            magmaLight.position.y = size / 2;
            group.add(magma, magmaLight);
            break;
            
        case 'obsidian':
            const obsidian = new THREE.Mesh(
                new THREE.BoxGeometry(size, size, size),
                materials.obsidian
            );
            obsidian.position.y = size / 2;
            obsidian.castShadow = true;
            group.add(obsidian);
            break;
            
        case 'neon-strip':
            const strip = new THREE.Mesh(
                new THREE.BoxGeometry(size * 0.1, size * 0.05, size),
                materials.neon
            );
            strip.position.y = size * 0.025;
            
            const stripLight = new THREE.PointLight(0xff00ff, 0.5, 3 * size);
            stripLight.position.y = size * 0.1;
            group.add(strip, stripLight);
            break;
            
        default:
            // Fall back to original function for other blocks
            return originalCreateBlock(type, size, color, rotation);
    }
    
    group.userData = { type: type, deletable: true, size: size, color: color };
    return group;
};
</script>

</body>
</html>



