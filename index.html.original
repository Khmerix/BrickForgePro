// Add visual feedback when placing blocks
function createPlacementRipple(position) {
    const geometry = new THREE.RingGeometry(0.1, 0.5, 32);
    const material = new THREE.MeshBasicMaterial({ 
        color: currentColor, 
        transparent: true, 
        opacity: 0.8,
        side: THREE.DoubleSide
    });
    const ripple = new THREE.Mesh(geometry, material);
    ripple.position.copy(position);
    ripple.position.y += 0.1;
    ripple.rotation.x = -Math.PI / 2;
    scene.add(ripple);
    
    let scale = 1;
    let opacity = 0.8;
    
    function animateRipple() {
        scale += 0.1;
        opacity -= 0.05;
        ripple.scale.setScalar(scale);
        ripple.material.opacity = opacity;
        
        if (opacity > 0) {
            requestAnimationFrame(animateRipple);
        } else {
            scene.remove(ripple);
        }
    }
    animateRipple();
}

// Hook ripple into placeBlock
const originalPlaceBlock = placeBlock;
placeBlock = function() {
    const ghostPos = ghostBlock ? ghostBlock.position.clone() : null;
    originalPlaceBlock();
    if (ghostPos) createPlacementRipple(ghostPos);
};

// ==================== MULTIPLAYER SYSTEM ====================

let ws = null;
let myUserId = null;
let myRole = 'student';
let myName = '';
let currentRoomId = null;
let roomUsers = new Map();
let remoteCursors = new Map();
let isConnected = false;
let reconnectAttempts = 0;
let maxReconnectAttempts = 5;

// WebSocket Connection
function connectWebSocket() {
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = protocol + '//' + window.location.host;
    
    updateConnectionStatus('connecting', 'Connecting...');
    
    ws = new WebSocket(wsUrl);
    
    ws.onopen = () => {
        console.log('WebSocket connected');
        isConnected = true;
        reconnectAttempts = 0;
        updateConnectionStatus('connected', 'Connected');
        
        // If we have user info, join
        if (myName) {
            onWsConnected();
        }
    };
    
    ws.onmessage = (event) => {
        const msg = JSON.parse(event.data);
        handleServerMessage(msg);
    };
    
    ws.onclose = () => {
        console.log('WebSocket disconnected');
        isConnected = false;
        updateConnectionStatus('disconnected', 'Disconnected');
        
        // Attempt to reconnect
        if (reconnectAttempts < maxReconnectAttempts) {
            reconnectAttempts++;
            setTimeout(connectWebSocket, 3000 * reconnectAttempts);
        }
    };
    
    ws.onerror = (err) => {
        console.error('WebSocket error:', err);
    };
}

function updateConnectionStatus(status, text) {
    const dot = document.getElementById('status-dot');
    const label = document.getElementById('status-text');
    if (dot && label) {
        dot.className = 'status-dot ' + status;
        label.textContent = text;
    }
}

function handleServerMessage(msg) {
    switch (msg.type) {
        case 'joined':
            myUserId = msg.userId;
            break;
            
        case 'roomCreated':
            showToast('Room created! Joining...', 'success');
            break;
            
        case 'roomJoined':
            enterRoom(msg);
            break;
            
        case 'userJoined':
            addUserToList(msg.user);
            addChatMessage({
                type: 'system',
                content: `?? ${msg.user.name} joined the room`
            });
            break;
            
        case 'userLeft':
            removeUserFromList(msg.userId);
            addChatMessage({
                type: 'system',
                content: `?? ${msg.name} left the room`
            });
            break;
            
        case 'blockPlaced':
            handleRemoteBlockPlace(msg.block);
            break;
            
        case 'blockDeleted':
            handleRemoteBlockDelete(msg.blockId);
            break;
            
        case 'blockPainted':
            handleRemoteBlockPaint(msg.blockId, msg.color);
            break;
            
        case 'chatMessage':
            addChatMessage(msg.message);
            break;
            
        case 'cursorUpdate':
            updateRemoteCursor(msg);
            break;
            
        case 'assignmentCreated':
            showToast('New assignment posted!', 'info');
            if (msg.systemMessage) addChatMessage(msg.systemMessage);
            break;
            
        case 'roomLockChanged':
            showToast(msg.locked ? 'Room locked' : 'Room unlocked', 'info');
            break;
            
        case 'roomCleared':
            clearAllBlocks();
            showToast('Room cleared by teacher', 'warning');
            break;
            
        case 'roomList':
            updateRoomList(msg.rooms);
            break;
            
        case 'kicked':
            alert('You were removed from the room: ' + msg.reason);
            backToLobby();
            break;
            
        case 'error':
            showToast(msg.message, 'error');
            break;
            
        case 'submitSuccess':
            showToast(msg.message, 'success');
            break;
    }
}

// ==================== AUTH & LOBBY ====================

function selectRole(role) {
    myRole = role;
    document.querySelectorAll('.role-option').forEach(el => {
        el.classList.toggle('selected', el.dataset.role === role);
    });
}

function joinApp() {
    const nameInput = document.getElementById('auth-name');
    myName = nameInput.value.trim();
    
    if (!myName) {
        showToast('Please enter your name', 'warning');
        return;
    }
    
    // Hide auth, show lobby
    document.getElementById('auth-screen').classList.add('hidden');
    document.getElementById('lobby-screen').classList.add('active');
    document.getElementById('lobby-username').textContent = myName;
    
    // Show create room panel if teacher
    if (myRole === 'teacher') {
        document.getElementById('create-room-panel').style.display = 'block';
        const demoPanel = document.getElementById('demo-panel');
        if (demoPanel) demoPanel.style.display = 'block';
    }
    
    // Connect to server - will auto-join when connected
    connectWebSocket();
}

// Called when WebSocket connects successfully
function onWsConnected() {
    if (!myName) return;
    
    // Send join message
    ws.send(JSON.stringify({
        type: 'join',
        name: myName,
        role: myRole
    }));
    
    // Get room list
    refreshRoomList();
}

function logout() {
    location.reload();
}

function refreshRoomList() {
    if (ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({ type: 'getRoomList' }));
    } else {
        // Show message if not connected
        const container = document.getElementById('rooms-container');
        if (container) {
            container.innerHTML = `
                <div style="text-align: center; color: var(--text-secondary); padding: 40px;">
                    <div style="font-size: 48px; margin-bottom: 10px;">??</div>
                    <div>Connecting to server...</div>
                    <div style="font-size: 12px; margin-top: 10px;">Please wait or refresh the page</div>
                </div>
            `;
        }
    }
}

function updateRoomList(rooms) {
    const container = document.getElementById('rooms-container');
    
    if (rooms.length === 0) {
        container.innerHTML = `
            <div style="text-align: center; color: var(--text-secondary); padding: 40px;">
                <div style="font-size: 48px; margin-bottom: 10px;">??</div>
                <div>No active projects yet.</div>
                ${myRole === 'teacher' ? '<div style="margin-top: 10px;">Create one to get started!</div>' : ''}
            </div>
        `;
        return;
    }
    
    container.innerHTML = rooms.map(room => `
        <div class="room-item ${room.isLocked ? 'locked' : ''}" onclick="joinRoom('${room.id}')">
            <div>
                <div class="room-name">${room.name}</div>
                <div class="room-info">
                    ${room.hasAssignment ? '?? Has Assignment' : '?? Free Build'} ? 
                    ${room.userCount} user${room.userCount !== 1 ? 's' : ''}
                </div>
            </div>
            <div class="room-users">${room.userCount}</div>
        </div>
    `).join('');
}

function createRoom() {
    const name = document.getElementById('room-name').value.trim();
    const assignmentTitle = document.getElementById('assignment-title').value.trim();
    const assignmentDesc = document.getElementById('assignment-desc').value.trim();
    
    if (!name) {
        showToast('Please enter a project name', 'warning');
        return;
    }
    
    const assignment = assignmentTitle ? {
        title: assignmentTitle,
        description: assignmentDesc,
        createdAt: Date.now()
    } : null;
    
    ws.send(JSON.stringify({
        type: 'createRoom',
        roomName: name,
        assignment: assignment
    }));
}

function joinRoom(roomId) {
    ws.send(JSON.stringify({
        type: 'joinRoom',
        roomId: roomId
    }));
}

function joinRoomByCode() {
    const code = document.getElementById('join-code').value.trim();
    if (code) joinRoom(code);
}

// ==================== ROOM MANAGEMENT ====================

function enterRoom(roomData) {
    currentRoomId = roomData.roomId;
    
    // Hide lobby
    document.getElementById('lobby-screen').classList.remove('active');
    
    // Show game UI
    document.getElementById('connection-status').style.display = 'flex';
    document.getElementById('user-list-panel').style.display = 'block';
    document.getElementById('chat-container').style.display = 'flex';
    
    // Show role-specific controls
    if (myRole === 'teacher') {
        document.getElementById('teacher-controls').style.display = 'flex';
    } else {
        document.getElementById('student-controls').style.display = 'flex';
    }
    
    // Populate user list
    document.getElementById('user-list').innerHTML = '';
    roomData.users.forEach(user => addUserToList(user));
    updateChatUserCount(roomData.users.length);
    
    // Populate chat history
    document.getElementById('chat-messages').innerHTML = '';
    roomData.chatHistory.forEach(msg => addChatMessage(msg));
    
    // Load existing blocks
    if (roomData.blocks) {
        roomData.blocks.forEach(block => {
            const newBlock = createRealisticBlock(block.type, block.size, block.color, block.rotation);
            newBlock.position.set(block.position.x, block.position.y, block.position.z);
            newBlock.rotation.y = block.rotation;
            newBlock.userData = { 
                ...newBlock.userData, 
                id: block.id,
                placedBy: block.placedBy 
            };
            scene.add(newBlock);
            blocks.push(newBlock);
        });
        updateCount();
    }
    
    // Show assignment if exists
    if (roomData.assignment) {
        showAssignment(roomData.assignment);
    }
    
    showToast(`Joined room: ${roomData.roomName}`, 'success');
}

function backToLobby() {
    if (ws) {
        ws.send(JSON.stringify({ type: 'leaveRoom' }));
    }
    
    // Clear blocks
    blocks.forEach(b => scene.remove(b));
    blocks = [];
    updateCount();
    
    // Hide game UI
    document.getElementById('connection-status').style.display = 'none';
    document.getElementById('user-list-panel').style.display = 'none';
    document.getElementById('chat-container').style.display = 'none';
    document.getElementById('teacher-controls').style.display = 'none';
    document.getElementById('student-controls').style.display = 'none';
    
    // Clear remote cursors
    remoteCursors.forEach(cursor => scene.remove(cursor));
    remoteCursors.clear();
    
    // Show lobby
    document.getElementById('lobby-screen').classList.add('active');
    currentRoomId = null;
    
    refreshRoomList();
}

function addUserToList(user) {
    roomUsers.set(user.id, user);
    
    const container = document.getElementById('user-list');
    const userEl = document.createElement('div');
    userEl.className = 'user-item';
    userEl.id = 'user-' + user.id;
    userEl.innerHTML = `
        <div class="user-avatar" style="background: ${user.color}20; color: ${user.color}; border: 2px solid ${user.color};">
            ${user.name.charAt(0).toUpperCase()}
        </div>
        <div>
            <div class="user-name">${user.name}</div>
            <div class="user-role">${user.role === 'teacher' ? '?? Teacher' : '?? Student'}</div>
        </div>
    `;
    container.appendChild(userEl);
    updateChatUserCount(roomUsers.size);
}

function removeUserFromList(userId) {
    roomUsers.delete(userId);
    const el = document.getElementById('user-' + userId);
    if (el) el.remove();
    updateChatUserCount(roomUsers.size);
}

function updateChatUserCount(count) {
    document.getElementById('chat-user-count').textContent = count;
}

// ==================== CHAT SYSTEM ====================

let chatMinimized = false;

function toggleChat() {
    chatMinimized = !chatMinimized;
    document.getElementById('chat-container').classList.toggle('minimized', chatMinimized);
    document.getElementById('chat-toggle').textContent = chatMinimized ? '?' : '?';
}

function sendChat() {
    const input = document.getElementById('chat-input');
    const content = input.value.trim();
    
    if (!content || !currentRoomId) return;
    
    ws.send(JSON.stringify({
        type: 'chat',
        content: content
    }));
    
    input.value = '';
}

function addChatMessage(msg) {
    const container = document.getElementById('chat-messages');
    const msgEl = document.createElement('div');
    msgEl.className = 'chat-message ' + (msg.type === 'system' ? 'system' : 
                                         (msg.sender && msg.sender.id === myUserId ? 'own' : 'other'));
    
    if (msg.type === 'system') {
        msgEl.textContent = msg.content;
    } else {
        const senderName = msg.sender ? msg.sender.name : 'Unknown';
        const senderColor = msg.sender ? msg.sender.color : '#888';
        msgEl.innerHTML = `
            <div class="chat-sender" style="color: ${senderColor}">${senderName}</div>
            <div>${escapeHtml(msg.content)}</div>
        `;
    }
    
    container.appendChild(msgEl);
    container.scrollTop = container.scrollHeight;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// ==================== MULTIPLAYER BLOCK SYNC ====================

// Override placeBlock to sync
const originalPlaceBlockMP = placeBlock;
placeBlock = function() {
    const originalPos = ghostBlock ? ghostBlock.position.clone() : null;
    
    originalPlaceBlockMP();
    
    // Sync to server
    if (currentRoomId && ws && ws.readyState === WebSocket.OPEN && blocks.length > 0) {
        const newBlock = blocks[blocks.length - 1];
        ws.send(JSON.stringify({
            type: 'blockPlace',
            block: {
                type: newBlock.userData.type,
                size: newBlock.userData.size,
                position: {
                    x: newBlock.position.x,
                    y: newBlock.position.y,
                    z: newBlock.position.z
                },
                rotation: newBlock.rotation.y,
                color: newBlock.userData.color || currentColor
            }
        }));
    }
};

// Override eraseBlock to sync
const originalEraseBlockMP = eraseBlock;
eraseBlock = function(block) {
    if (currentRoomId && ws && ws.readyState === WebSocket.OPEN) {
        ws.send(JSON.stringify({
            type: 'blockDelete',
            blockId: block.userData.id
        }));
    }
    originalEraseBlockMP(block);
};

function handleRemoteBlockPlace(blockData) {
    const block = createRealisticBlock(blockData.type, blockData.size, blockData.color, blockData.rotation);
    block.position.set(blockData.position.x, blockData.position.y, blockData.position.z);
    block.rotation.y = blockData.rotation;
    block.userData = { 
        ...block.userData, 
        id: blockData.id,
        placedBy: blockData.placedBy 
    };
    
    scene.add(block);
    blocks.push(block);
    animateBlockPlacement(block);
    updateCount();
}

function handleRemoteBlockDelete(blockId) {
    const block = blocks.find(b => b.userData.id === blockId);
    if (block) {
        scene.remove(block);
        blocks = blocks.filter(b => b !== block);
        updateCount();
    }
}

function handleRemoteBlockPaint(blockId, color) {
    const block = blocks.find(b => b.userData.id === blockId);
    if (block) {
        block.traverse(child => {
            if (child.isMesh && child.material) {
                child.material = child.material.clone();
                child.material.color.setHex(color);
            }
        });
    }
}

