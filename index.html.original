<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BrickForge Pro - Realistic Builder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/OBJLoader.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        
        :root {
            --bg-primary: #0a0a0a;
            --glass-bg: rgba(15, 15, 15, 0.95);
            --glass-border: rgba(255,255,255,0.1);
            --accent: #00d4ff;
            --accent-glow: rgba(0,212,255,0.4);
            --text-primary: #fff;
            --text-secondary: #888;
        }
        
        [data-theme="light"] {
            --bg-primary: #f0f0f0;
            --glass-bg: rgba(255, 255, 255, 0.9);
            --glass-border: rgba(0,0,0,0.1);
            --accent: #0066cc;
            --accent-glow: rgba(0,102,204,0.3);
            --text-primary: #1a1a1a;
            --text-secondary: #666;
        }
        
        body { margin: 0; overflow: hidden; font-family: 'Inter', sans-serif; background: var(--bg-primary); user-select: none; transition: background 0.5s ease; }
        
        .glass-panel {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            backdrop-filter: blur(12px);
            transition: all 0.3s ease;
        }
        
        .glass-btn {
            background: linear-gradient(145deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.05) 100%);
            border: 1px solid var(--glass-border);
            color: var(--text-primary);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-btn:hover { 
            background: rgba(255,255,255,0.25); 
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }
        .glass-btn:active { transform: scale(0.95); }
        .glass-btn.active { 
            border-color: var(--accent); 
            box-shadow: 0 0 20px var(--accent-glow); 
            background: linear-gradient(145deg, rgba(0,212,255,0.2) 0%, rgba(0,212,255,0.1) 100%);
        }
        
        .ui-retracted-top { transform: translateY(-150%); opacity: 0; }
        .ui-retracted-bottom { transform: translateY(150%); opacity: 0; }
        
        .block-btn {
            width: 70px; height: 70px; border-radius: 14px;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            cursor: pointer; margin: 3px; border: 2px solid transparent;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); flex-shrink: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0.05));
            position: relative; overflow: hidden;
        }
        .block-btn::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }
        .block-btn:hover::before { left: 100%; }
        .block-btn:hover { 
            transform: scale(1.1) rotate(2deg); 
            border-color: rgba(255,255,255,0.4);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }
        .block-btn.selected { 
            border-color: var(--accent); 
            box-shadow: 0 0 25px var(--accent-glow),
                        inset 0 0 20px rgba(0,212,255,0.1);
            animation: pulse-selected 2s infinite;
        }
        @keyframes pulse-selected {
            0%, 100% { transform: scale(1.05); }
            50% { transform: scale(1.08); }
        }
        .block-btn .icon { font-size: 28px; margin-bottom: 4px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)); transition: transform 0.3s; }
        .block-btn:hover .icon { transform: scale(1.2) rotate(-5deg); }
        .block-btn .label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-primary); }
        
        #canvas-container { width: 100vw; height: 100vh; position: fixed; top: 0; left: 0; z-index: 0; }
        .ui-layer { position: relative; z-index: 10; pointer-events: none; height: 100vh; display: flex; flex-direction: column; justify-content: space-between; padding: 16px; }
        .ui-interactive { pointer-events: auto; }
        
        .scroll-row { display: flex; overflow-x: auto; gap: 6px; padding: 4px; scrollbar-width: thin; }
        .scroll-row::-webkit-scrollbar { height: 4px; }
        .scroll-row::-webkit-scrollbar-track { background: rgba(255,255,255,0.1); border-radius: 2px; }
        .scroll-row::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }
        
        /* Bottom panel scrolling */
        #bottom-panel .scroll-row {
            max-height: 200px;
            overflow-y: auto;
            flex-wrap: wrap;
            overflow-x: hidden;
        }
        
        #bottom-panel .scroll-row::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        
        #bottom-panel .scroll-row::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05);
            border-radius: 3px;
        }
        
        #bottom-panel .scroll-row::-webkit-scrollbar-thumb {
            background: var(--accent);
            border-radius: 3px;
        }
        
        .category-label { font-size: 10px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; margin: 8px 4px 4px 4px; }
        
        .placement-hud {
            position: fixed; bottom: 140px; left: 50%; transform: translateX(-50%);
            background: rgba(0,0,0,0.85); color: var(--accent);
            padding: 12px 24px; border-radius: 30px; font-size: 13px; font-weight: 600;
            border: 2px solid var(--accent); backdrop-filter: blur(10px);
            display: none; box-shadow: 0 0 30px var(--accent-glow);
            animation: float-hud 3s ease-in-out infinite;
        }
        @keyframes float-hud {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(-5px); }
        }
        .placement-hud.visible { display: block; }
        
        /* Loading Screen */
        #loading-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
            z-index: 9999; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            transition: opacity 0.8s ease, visibility 0.8s;
        }
        #loading-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
        .loading-logo { font-size: 48px; font-weight: bold; color: var(--accent); margin-bottom: 20px; }
        .loading-bar { width: 300px; height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
        .loading-progress { width: 0%; height: 100%; background: linear-gradient(90deg, var(--accent), #00ff88); transition: width 0.3s; }
        .loading-text { color: var(--text-secondary); margin-top: 15px; font-size: 14px; }
        
        /* Particle canvas overlay */
        #particle-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none; z-index: 5;
        }
        
        /* Toast notifications */
        .toast-container {
            position: fixed; top: 20px; right: 20px;
            z-index: 1000; display: flex; flex-direction: column; gap: 10px;
        }
        .toast {
            background: var(--glass-bg);
            border: 1px solid var(--accent);
            color: var(--text-primary);
            padding: 12px 20px; border-radius: 12px;
            backdrop-filter: blur(10px);
            transform: translateX(150%);
            transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        }
        .toast.show { transform: translateX(0); }
        
        /* Theme toggle animation */
        .theme-icon { transition: transform 0.5s ease; }
        .theme-icon:hover { transform: rotate(180deg); }
        
        /* ==================== BLUEPRINT MODE ==================== */
        .blueprint-mode #canvas-container {
            filter: contrast(1.2) sepia(0.3) hue-rotate(180deg);
        }
        .blueprint-mode .glass-panel {
            background: rgba(0, 30, 60, 0.95);
            border-color: rgba(100, 200, 255, 0.3);
        }
        .blueprint-mode .glass-btn {
            background: linear-gradient(145deg, rgba(100, 200, 255, 0.15) 0%, rgba(100, 200, 255, 0.05) 100%);
            border-color: rgba(100, 200, 255, 0.3);
        }
        
        /* Blueprint Grid Overlay */
        #blueprint-grid {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none; z-index: 1;
            background-image: 
                linear-gradient(rgba(0, 150, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 150, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            display: none;
        }
        .blueprint-mode #blueprint-grid { display: block; }
        
        /* ==================== ENVIRONMENT SELECTOR ==================== */
        #environment-panel {
            position: fixed;
            top: 100px;
            right: 20px;
            width: 220px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 16px;
            z-index: 90;
            display: none;
        }
        #environment-panel.active { display: block; }
        .env-title {
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .env-option {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 6px;
        }
        .env-option:hover {
            background: rgba(255,255,255,0.05);
        }
        .env-option.active {
            background: var(--accent);
            color: #000;
        }
        .env-icon { font-size: 20px; }
        .env-name { font-size: 13px; font-weight: 500; }
        .env-gravity {
            font-size: 10px;
            opacity: 0.7;
            margin-left: auto;
        }
        
        /* ==================== BLUEPRINT TOGGLE ==================== */
        #blueprint-toggle {
            position: fixed;
            top: 20px;
            right: 240px;
            z-index: 95;
        }
        
        /* ==================== DEMO MODE INDICATOR ==================== */
        #demo-indicator {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(90deg, #667eea, #764ba2);
            color: #fff;
            padding: 8px 24px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 14px;
            z-index: 100;
            display: none;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }
        #demo-indicator.active { display: block; }
        
        /* Floating action buttons */
        .fab-menu {
            position: fixed; bottom: 100px; left: 20px;
            display: flex; flex-direction: column; gap: 10px;
            z-index: 50;
        }
        .fab-btn {
            width: 50px; height: 50px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px;
            cursor: pointer;
            opacity: 0; transform: scale(0);
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
        .fab-menu.open .fab-btn { opacity: 1; transform: scale(1); }
        .fab-menu.open .fab-btn:nth-child(1) { transition-delay: 0.1s; }
        .fab-menu.open .fab-btn:nth-child(2) { transition-delay: 0.15s; }
        .fab-menu.open .fab-btn:nth-child(3) { transition-delay: 0.2s; }
        .fab-menu.open .fab-btn:nth-child(4) { transition-delay: 0.25s; }
        
        /* Time of day slider */
        .time-slider {
            -webkit-appearance: none; width: 100%; height: 6px;
            background: linear-gradient(90deg, #1a1a2e, #87CEEB, #ff6b35, #1a1a2e);
            border-radius: 3px; outline: none;
        }
        .time-slider::-webkit-slider-thumb {
            -webkit-appearance: none; width: 20px; height: 20px;
            background: var(--accent); border-radius: 50%;
            cursor: pointer; box-shadow: 0 0 15px var(--accent-glow);
        }
        
        /* Particle burst animation for UI */
        @keyframes particle-burst {
            0% { transform: scale(0); opacity: 1; }
            100% { transform: scale(2); opacity: 0; }
        }
        
        /* Glow effect on hover */
        .glow-effect {
            position: relative;
        }
        .glow-effect::after {
            content: '';
            position: absolute; inset: -2px;
            background: linear-gradient(45deg, var(--accent), transparent, var(--accent));
            border-radius: inherit;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
            filter: blur(10px);
        }
        .glow-effect:hover::after { opacity: 0.5; }
        
        /* Ripple effect */
        .ripple {
            position: relative; overflow: hidden;
        }
        .ripple::before {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            width: 0; height: 0;
            background: rgba(255,255,255,0.3);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }
        .ripple:active::before {
            width: 300px; height: 300px;
        }
        
        /* Tool transition */
        #canvas-container {
            transition: filter 0.3s;
        }
        #canvas-container.erase-mode {
            cursor: crosshair;
        }
        
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); }
        ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 4px; }
        
        /* Block preview glow */
        .block-preview {
            position: fixed;
            pointer-events: none;
            z-index: 100;
            border: 2px solid var(--accent);
            box-shadow: 0 0 30px var(--accent-glow);
            border-radius: 8px;
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        /* ==================== MULTIPLAYER STYLES ==================== */
        
        /* Auth Screen */
        #auth-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0f3460 100%);
            z-index: 10000;
            display: flex; align-items: center; justify-content: center;
            transition: opacity 0.5s, visibility 0.5s;
        }
        #auth-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
        .auth-box {
            background: var(--glass-bg);
            border: 1px solid var(--accent);
            border-radius: 20px;
            padding: 40px;
            width: 90%; max-width: 500px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 40px var(--accent-glow);
        }
        .auth-title {
            font-size: 32px; font-weight: bold;
            text-align: center; margin-bottom: 10px;
            background: linear-gradient(90deg, var(--accent), #00ff88);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .auth-subtitle {
            text-align: center; color: var(--text-secondary);
            margin-bottom: 30px;
        }
        .input-group { margin-bottom: 20px; }
        .input-group label {
            display: block; margin-bottom: 8px;
            color: var(--text-secondary); font-size: 14px;
        }
        .input-group input, .input-group select {
            width: 100%; padding: 12px 16px;
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--glass-border);
            border-radius: 10px;
            color: var(--text-primary);
            font-size: 16px;
            transition: border-color 0.3s, box-shadow 0.3s;
        }
        .input-group input:focus, .input-group select:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 15px var(--accent-glow);
        }
        .role-selector {
            display: flex; gap: 10px; margin-bottom: 20px;
        }
        .role-option {
            flex: 1; padding: 15px;
            background: rgba(0,0,0,0.3);
            border: 2px solid transparent;
            border-radius: 12px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .role-option:hover { background: rgba(255,255,255,0.05); }
        .role-option.selected {
            border-color: var(--accent);
            background: rgba(0,212,255,0.1);
        }
        .role-option .icon { font-size: 24px; margin-bottom: 5px; }
        .role-option .label { font-size: 14px; color: var(--text-secondary); }
        
        /* Lobby Screen */
        #lobby-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            z-index: 9999;
            display: none; flex-direction: column;
            padding: 20px;
        }
        #lobby-screen.active { display: flex; }
        .lobby-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px;
            background: var(--glass-bg);
            border-radius: 16px;
            margin-bottom: 20px;
        }
        .lobby-content {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 20px; flex: 1;
            overflow: hidden;
        }
        .room-list {
            background: var(--glass-bg);
            border-radius: 16px;
            padding: 20px;
            overflow-y: auto;
        }
        .room-item {
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex; justify-content: space-between; align-items: center;
        }
        .room-item:hover {
            border-color: var(--accent);
            transform: translateX(5px);
        }
        .room-item.locked { opacity: 0.5; pointer-events: none; }
        .room-name { font-weight: 600; color: var(--text-primary); }
        .room-info { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }
        .room-users { 
            background: var(--accent); 
            color: #000; 
            padding: 4px 10px; 
            border-radius: 20px; 
            font-size: 12px;
            font-weight: 600;
        }
        .lobby-sidebar {
            display: flex; flex-direction: column; gap: 20px;
        }
        .create-room-panel {
            background: var(--glass-bg);
            border-radius: 16px;
            padding: 20px;
        }
        
        /* Chat Box */
        #chat-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 350px;
            height: 400px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s, opacity 0.3s;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        }
        #chat-container.minimized {
            transform: translateY(calc(100% - 50px));
        }
        .chat-header {
            padding: 12px 16px;
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
        }
        .chat-title { font-weight: 600; color: var(--text-primary); }
        .chat-users { font-size: 12px; color: var(--text-secondary); }
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .chat-message {
            max-width: 85%;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.4;
            animation: message-slide 0.3s ease;
        }
        @keyframes message-slide {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .chat-message.own {
            align-self: flex-end;
            background: var(--accent);
            color: #000;
            border-bottom-right-radius: 4px;
        }
        .chat-message.other {
            align-self: flex-start;
            background: rgba(255,255,255,0.1);
            color: var(--text-primary);
            border-bottom-left-radius: 4px;
        }
        .chat-message.system {
            align-self: center;
            background: rgba(255,200,0,0.2);
            color: #ffcc00;
            font-size: 12px;
            border-radius: 20px;
        }
        .chat-sender {
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 4px;
            opacity: 0.8;
        }
        .chat-input-container {
            padding: 12px;
            border-top: 1px solid var(--glass-border);
            display: flex;
            gap: 8px;
        }
        .chat-input {
            flex: 1;
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 10px 16px;
            color: var(--text-primary);
            font-size: 14px;
        }
        .chat-input:focus {
            outline: none;
            border-color: var(--accent);
        }
        .chat-send-btn {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: var(--accent);
            border: none;
            color: #000;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s;
        }
        .chat-send-btn:hover { transform: scale(1.1); }
        
        /* User List */
        #user-list-panel {
            position: fixed;
            top: 100px;
            left: 20px;
            width: 200px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 16px;
            z-index: 90;
        }
        .user-list-title {
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--glass-border);
        }
        .user-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px;
            border-radius: 8px;
            transition: background 0.2s;
        }
        .user-item:hover { background: rgba(255,255,255,0.05); }
        .user-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: bold;
        }
        .user-name {
            font-size: 14px;
            color: var(--text-primary);
        }
        .user-role {
            font-size: 10px;
            color: var(--text-secondary);
        }
        
        /* Teacher Controls */
        .teacher-controls {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--glass-bg);
            border: 1px solid var(--accent);
            border-radius: 12px;
            padding: 10px 20px;
            display: flex;
            gap: 15px;
            z-index: 95;
            align-items: center;
        }
        .teacher-badge {
            background: linear-gradient(90deg, #ff6b35, #f7931e);
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .control-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid var(--glass-border);
            color: var(--text-primary);
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
        }
        .control-btn:hover {
            background: rgba(255,255,255,0.2);
            border-color: var(--accent);
        }
        
        /* Assignment Panel */
        #assignment-panel {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%; max-width: 600px;
            max-height: 80vh;
            background: var(--glass-bg);
            border: 1px solid var(--accent);
            border-radius: 20px;
            padding: 30px;
            z-index: 200;
            display: none;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }
        #assignment-panel.active { display: block; }
        .assignment-title {
            font-size: 24px; font-weight: bold;
            color: var(--text-primary);
            margin-bottom: 10px;
        }
        .assignment-description {
            color: var(--text-secondary);
            margin-bottom: 20px;
            line-height: 1.6;
        }
        .assignment-meta {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            font-size: 14px;
        }
        .assignment-meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
        }
        
        /* Remote Cursors */
        .remote-cursor {
            position: absolute;
            pointer-events: none;
            z-index: 50;
            transition: transform 0.1s linear;
        }
        .cursor-label {
            position: absolute;
            top: 15px; left: 10px;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            white-space: nowrap;
        }
        
        /* Connection Status */
        #connection-status {
            position: fixed;
            top: 20px;
            right: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--glass-bg);
            padding: 8px 16px;
            border-radius: 20px;
            z-index: 100;
        }
        .status-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        .status-dot.connected { background: #00ff88; }
        .status-dot.disconnected { background: #ff4444; }
        .status-dot.connecting { background: #ffcc00; }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
    </style>
</head>
<body>

<!-- Auth Screen -->
<div id="auth-screen">
    <div class="auth-box">
        <div class="auth-title">?? BrickForge Pro</div>
        <div class="auth-subtitle">Collaborative 3D Building for Education</div>
        
        <div class="input-group">
            <label>Your Name</label>
            <input type="text" id="auth-name" placeholder="Enter your name" maxlength="20">
        </div>
        
        <div style="margin-bottom: 10px; color: var(--text-secondary); font-size: 14px;">Select your role:</div>
        <div class="role-selector">
            <div class="role-option selected" data-role="student" onclick="selectRole('student')">
                <div class="icon">??</div>
                <div class="label">Student</div>
            </div>
            <div class="role-option" data-role="teacher" onclick="selectRole('teacher')">
                <div class="icon">?????</div>
                <div class="label">Teacher</div>
            </div>
        </div>
        
        <button onclick="joinApp()" class="glass-btn" style="width: 100%; padding: 15px; border-radius: 12px; font-size: 16px; font-weight: 600; margin-top: 10px;">
            Enter Platform
        </button>
    </div>
</div>

<!-- Lobby Screen -->
<div id="lobby-screen">
    <div class="lobby-header">
        <div>
            <div style="font-size: 24px; font-weight: bold; color: var(--text-primary);">?? Project Lobby</div>
            <div style="color: var(--text-secondary); font-size: 14px;">Welcome, <span id="lobby-username">User</span></div>
        </div>
        <button onclick="logout()" class="glass-btn" style="padding: 10px 20px; border-radius: 10px;">Logout</button>
    </div>
    
    <div class="lobby-content">
        <div class="room-list">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div style="font-size: 18px; font-weight: 600; color: var(--text-primary);">Active Projects</div>
                <button onclick="refreshRoomList()" class="glass-btn" style="padding: 8px 16px; border-radius: 8px; font-size: 13px;">?? Refresh</button>
            </div>
            <div id="rooms-container">
                <div style="text-align: center; color: var(--text-secondary); padding: 40px;">
                    Loading rooms...
                </div>
            </div>
        </div>
        
        <div class="lobby-sidebar" style="overflow-y: auto; max-height: calc(100vh - 150px);">
            <div class="create-room-panel" id="create-room-panel" style="display: none;">
                <div style="font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 15px;">Create New Project</div>
                <div class="input-group">
                    <label>Project Name</label>
                    <input type="text" id="room-name" placeholder="e.g., Medieval Castle">
                </div>
                <div class="input-group">
                    <label>Assignment Title</label>
                    <input type="text" id="assignment-title" placeholder="e.g., Build a castle with 4 towers">
                </div>
                <div class="input-group">
                    <label>Description</label>
                    <input type="text" id="assignment-desc" placeholder="Detailed instructions...">
                </div>
                <button onclick="createRoom()" class="glass-btn active" style="width: 100%; padding: 12px; border-radius: 10px; margin-top: 10px;">
                    Create Project Room
                </button>
            </div>
            
            <!-- Demo Mode Panel (Teachers only) -->
            <div class="create-room-panel" id="demo-panel" style="display: none; border: 2px solid #667eea;">
                <div style="font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px;">SOLO DEMO MODE</div>
                <div style="color: var(--text-secondary); font-size: 13px; margin-bottom: 15px;">
                    Practice building, test environments, or prepare examples without creating a room.
                </div>
                <button onclick="enterDemoMode()" class="glass-btn" style="width: 100%; padding: 12px; border-radius: 10px; background: linear-gradient(90deg, rgba(102,126,234,0.3), rgba(118,75,162,0.3)); border-color: #667eea;">
                    Enter Demo Mode
                </button>
            </div>
            
            <div class="create-room-panel">
                <div style="font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px;">Join with Code</div>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="join-code" placeholder="Room ID" style="flex: 1; background: rgba(0,0,0,0.3); border: 1px solid var(--glass-border); border-radius: 8px; padding: 10px; color: var(--text-primary);">
                    <button onclick="joinRoomByCode()" class="glass-btn" style="padding: 10px 20px; border-radius: 8px;">Join</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Blueprint Grid Overlay -->
<div id="blueprint-grid"></div>

<!-- Demo Mode Indicator -->
<div id="demo-indicator">?? DEMO MODE - Solo Building</div>

<!-- Environment Selector Panel -->
<div id="environment-panel">
    <div class="env-title">?? Environment</div>
    <div class="env-option active" data-env="earth" onclick="setEnvironment('earth')">
        <span class="env-icon">??</span>
        <span class="env-name">Earth</span>
        <span class="env-gravity">1.0g</span>
    </div>
    <div class="env-option" data-env="mars" onclick="setEnvironment('mars')">
        <span class="env-icon">??</span>
        <span class="env-name">Mars</span>
        <span class="env-gravity">0.38g</span>
    </div>
    <div class="env-option" data-env="moon" onclick="setEnvironment('moon')">
        <span class="env-icon">??</span>
        <span class="env-name">Moon</span>
        <span class="env-gravity">0.16g</span>
    </div>
    <div class="env-option" data-env="desert" onclick="setEnvironment('desert')">
        <span class="env-icon">???</span>
        <span class="env-name">Desert</span>
        <span class="env-gravity">1.0g</span>
    </div>
    <div class="env-option" data-env="jungle" onclick="setEnvironment('jungle')">
        <span class="env-icon">??</span>
        <span class="env-name">Jungle</span>
        <span class="env-gravity">1.0g</span>
    </div>
    <div class="env-option" data-env="island" onclick="setEnvironment('island')">
        <span class="env-icon">???</span>
        <span class="env-name">Tropical Island</span>
        <span class="env-gravity">1.0g</span>
    </div>
    <div class="env-option" data-env="arctic" onclick="setEnvironment('arctic')">
        <span class="env-icon">??</span>
        <span class="env-name">Arctic</span>
        <span class="env-gravity">1.0g</span>
    </div>
    <div class="env-option" data-env="volcanic" onclick="setEnvironment('volcanic')">
        <span class="env-icon">??</span>
        <span class="env-name">Volcanic</span>
        <span class="env-gravity">1.0g</span>
    </div>
</div>

<!-- Loading Screen -->
<div id="loading-screen">
    <div class="loading-logo">?? BrickForge Pro</div>
    <div class="loading-bar"><div class="loading-progress" id="loading-progress"></div></div>
    <div class="loading-text" id="loading-text">Initializing Engine...</div>
</div>

<!-- Connection Status -->
<div id="connection-status" style="display: none;">
    <div class="status-dot connecting" id="status-dot"></div>
    <span id="status-text" style="color: var(--text-secondary); font-size: 13px;">Connecting...</span>
</div>

<!-- User List Panel -->
<div id="user-list-panel" style="display: none;">
    <div class="user-list-title">?? Team Members</div>
    <div id="user-list"></div>
</div>

<!-- Blueprint Toggle -->
<button id="blueprint-toggle" class="glass-btn" onclick="toggleBlueprint()" title="Blueprint Mode" style="display: none;">
    ?? Blueprint
</button>

<!-- Teacher Controls -->
<div id="teacher-controls" class="teacher-controls" style="display: none;">
    <span class="teacher-badge">?? Teacher Mode</span>
    <button onclick="showAssignmentModal()" class="control-btn">?? Assignment</button>
    <button onclick="toggleRoomLock()" class="control-btn" id="lock-btn">?? Unlock Room</button>
    <button onclick="toggleEnvironmentPanel()" class="control-btn">?? Environment</button>
    <button onclick="toggleBlueprint()" class="control-btn" id="blueprint-btn">?? Blueprint</button>
    <button onclick="clearRoom()" class="control-btn">??? Clear All</button>
    <button onclick="backToLobby()" class="control-btn">? Leave Room</button>
</div>

<!-- Demo Mode Controls (Solo Building) -->
<div id="demo-controls" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); display: none; z-index: 95;">
    <div style="background: var(--glass-bg); border: 1px solid #667eea; border-radius: 12px; padding: 10px 20px; display: flex; gap: 15px; align-items: center;">
        <span style="background: linear-gradient(90deg, #667eea, #764ba2); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;">?? Demo Mode</span>
        <button onclick="toggleEnvironmentPanel()" class="control-btn">?? Environment</button>
        <button onclick="toggleBlueprint()" class="control-btn" id="demo-blueprint-btn">?? Blueprint</button>
        <button onclick="saveDemoProject()" class="control-btn">?? Save Project</button>
        <button onclick="backToLobby()" class="control-btn">? Exit Demo</button>
    </div>
</div>

<!-- Student Controls -->
<div id="student-controls" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); display: none; z-index: 95;">
    <div style="background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 12px; padding: 10px 20px; display: flex; gap: 15px; align-items: center;">
        <span style="background: linear-gradient(90deg, #667eea, #764ba2); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;">?? Student</span>
        <button onclick="submitAssignment()" class="control-btn">?? Submit Work</button>
        <button onclick="viewAssignment()" class="control-btn">?? View Assignment</button>
        <button onclick="backToLobby()" class="control-btn">? Leave</button>
    </div>
</div>

<!-- Chat Container -->
<div id="chat-container" style="display: none;">
    <div class="chat-header" onclick="toggleChat()">
        <div>
            <div class="chat-title">?? Team Chat</div>
            <div class="chat-users"><span id="chat-user-count">0</span> users online</div>
        </div>
        <span id="chat-toggle">?</span>
    </div>
    <div class="chat-messages" id="chat-messages"></div>
    <div class="chat-input-container">
        <input type="text" class="chat-input" id="chat-input" placeholder="Type a message..." onkeypress="if(event.key==='Enter')sendChat()">
        <button class="chat-send-btn" onclick="sendChat()">?</button>
    </div>
</div>

<!-- Assignment Modal -->
<div id="assignment-panel" style="overflow-y: auto; max-height: 80vh;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; position: sticky; top: 0; background: var(--glass-bg); padding: 10px 0; z-index: 10;">
        <div class="assignment-title">?? Assignment Details</div>
        <button onclick="closeAssignmentModal()" class="glass-btn" style="width: 40px; height: 40px; border-radius: 50%;">?</button>
    </div>
    <div id="assignment-content" style="overflow-y: auto; max-height: 60vh;">
        <div class="assignment-description">Loading...</div>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container" id="toast-container"></div>

<div id="canvas-container"></div>

<div class="ui-layer">
    <!-- Top Panel -->
    <div class="flex justify-between items-start ui-interactive" id="top-panel">
        <div class="glass-panel rounded-2xl p-4 max-w-md">
            <button onclick="toggleUI()" class="absolute -bottom-3 left-1/2 transform -translate-x-1/2 w-8 h-5 bg-gray-700 rounded-b-lg text-xs flex items-center justify-center hover:bg-gray-600 transition-colors">?</button>
            
            <div class="flex items-center justify-between mb-3">
                <h1 class="text-xl font-bold text-white tracking-tight">BrickForge <span class="text-cyan-400">Pro</span></h1>
                <div class="flex gap-2">
                    <button onclick="undo()" class="glass-btn w-10 h-10 rounded-lg flex items-center justify-center text-lg" title="Undo">??</button>
                    <button onclick="redo()" class="glass-btn w-10 h-10 rounded-lg flex items-center justify-center text-lg" title="Redo">??</button>
                    <button onclick="toggleUI()" class="glass-btn w-10 h-10 rounded-lg flex items-center justify-center text-sm" title="Hide UI">???</button>
                </div>
            </div>
            
            <div class="grid grid-cols-4 gap-2 mb-3">
                <button onclick="setTool('build')" class="glass-btn py-2 rounded-lg text-xs font-bold active" id="tool-build">BUILD</button>
                <button onclick="setTool('paint')" class="glass-btn py-2 rounded-lg text-xs font-bold" id="tool-paint">PAINT</button>
                <button onclick="setTool('erase')" class="glass-btn py-2 rounded-lg text-xs font-bold" id="tool-erase">ERASE</button>
                <button onclick="setTool('select')" class="glass-btn py-2 rounded-lg text-xs font-bold" id="tool-select">SELECT</button>
            </div>
            
            <div class="flex justify-between items-center text-xs" style="color: var(--text-secondary);">
                <span>Blocks: <span id="block-count" class="font-bold text-lg" style="color: var(--text-primary);">0</span></span>
                <span class="font-semibold tracking-wide" style="color: var(--accent);">[B] Place � [R] Rotate</span>
            </div>
        </div>
        
        <div class="glass-panel rounded-2xl p-3 flex flex-col gap-2">
            <button onclick="resetCamera()" class="glass-btn w-12 h-12 rounded-xl flex items-center justify-center text-xl" title="Reset View">�</button>
            <button onclick="toggleGrid()" class="glass-btn w-12 h-12 rounded-xl flex items-center justify-center text-lg active" id="grid-btn">?</button>
            <button onclick="rotateBlock()" class="glass-btn w-12 h-12 rounded-xl flex items-center justify-center text-xl" title="Rotate Block">?</button>
            <button onclick="toggleSnap()" class="glass-btn active w-12 h-12 rounded-xl flex items-center justify-center text-lg" id="snap-btn" title="Grid Snap">?</button>
            <button onclick="toggleWeather()" class="glass-btn w-12 h-12 rounded-xl flex items-center justify-center text-lg" id="weather-btn" title="Toggle Weather">???</button>
            <button onclick="toggleAutoRotate()" class="glass-btn w-12 h-12 rounded-xl flex items-center justify-center text-lg" id="rotate-btn" title="Auto Rotate">??</button>
        </div>
    </div>
    
    <!-- Day/Night Slider -->
    <div class="glass-panel rounded-xl p-3 ui-interactive" style="position: absolute; top: 50%; right: 20px; transform: translateY(-50%); width: 50px;">
        <input type="range" min="0" max="24" value="12" class="time-slider" id="time-slider" orient="vertical" style="writing-mode: bt-lr; -webkit-appearance: slider-vertical; height: 200px; width: 30px;" oninput="setTimeOfDay(this.value)">
        <div class="text-center text-xs mt-2" style="color: var(--text-secondary);">??</div>
    </div>
    
    <div class="placement-hud" id="placement-hud">
        <span id="hud-coords">X: 0 Y: 0 Z: 0</span>
    </div>
    
    <!-- Bottom Panel -->
    <div class="glass-panel rounded-2xl p-4 ui-interactive w-full max-w-6xl mx-auto mb-4" id="bottom-panel" style="max-height: 280px; display: flex; flex-direction: column;">
        <button onclick="toggleUI()" class="absolute -top-3 left-1/2 transform -translate-x-1/2 w-8 h-5 bg-gray-700 rounded-t-lg text-xs flex items-center justify-center hover:bg-gray-600 transition-colors">?</button>
        
        <div class="flex gap-3 mb-3 items-center overflow-x-auto pb-2 border-b border-gray-800" style="flex-shrink: 0;">
            <div class="flex gap-1">
                <button onclick="setBlockSize(0.5)" class="glass-btn px-4 py-2 rounded-lg text-xs font-bold" id="size-05">��</button>
                <button onclick="setBlockSize(1)" class="glass-btn active px-4 py-2 rounded-lg text-xs font-bold" id="size-1">1�</button>
                <button onclick="setBlockSize(2)" class="glass-btn px-4 py-2 rounded-lg text-xs font-bold" id="size-2">2�</button>
                <button onclick="setBlockSize(4)" class="glass-btn px-4 py-2 rounded-lg text-xs font-bold" id="size-4">4�</button>
            </div>
            <div class="w-px h-8 bg-gray-700"></div>
            <div class="flex gap-1" id="color-row"></div>
        </div>
        
        <div class="scroll-row" style="overflow-y: auto; flex: 1; max-height: 160px; flex-wrap: nowrap; flex-direction: column; overflow-x: hidden; align-content: flex-start; gap: 8px;">
                            <!-- Architecture -->
            <div class="flex flex-col mb-2">
                <div class="category-label">Architecture</div>
                <div class="flex flex-wrap">
                    <div class="block-btn selected" onclick="selectBlock('cube')" id="btn-cube"><div class="icon"><i class="fas fa-cube"></i></div><div class="label">Brick</div></div>
                    <div class="block-btn" onclick="selectBlock('slope')" id="btn-slope"><div class="icon"><i class="fas fa-mountain"></i></div><div class="label">Roof</div></div>
                    <div class="block-btn" onclick="selectBlock('stair')" id="btn-stair"><div class="icon"><i class="fas fa-stairs"></i></div><div class="label">Stair</div></div>
                    <div class="block-btn" onclick="selectBlock('window')" id="btn-window"><div class="icon"><i class="fas fa-window-maximize"></i></div><div class="label">Window</div></div>
                    <div class="block-btn" onclick="selectBlock('door')" id="btn-door"><div class="icon"><i class="fas fa-door-open"></i></div><div class="label">Door</div></div>
                    <div class="block-btn" onclick="selectBlock('fence')" id="btn-fence"><div class="icon"><i class="fas fa-border-all"></i></div><div class="label">Fence</div></div>
                </div>
            </div>
            
            <!-- Columns -->
            <div class="flex flex-col mb-2">
                <div class="category-label">Columns</div>
                <div class="flex flex-wrap">
                    <div class="block-btn" onclick="selectBlock('pillar')" id="btn-pillar"><div class="icon"><i class="fas fa-grip-lines-vertical"></i></div><div class="label">Column</div></div>
                    <div class="block-btn" onclick="selectBlock('arch')" id="btn-arch"><div class="icon"><i class="fas fa-archway"></i></div><div class="label">Arch</div></div>
                    <div class="block-btn" onclick="selectBlock('cylinder')" id="btn-cylinder"><div class="icon"><i class="fas fa-database"></i></div><div class="label">Round</div></div>
                    <div class="block-btn" onclick="selectBlock('plate')" id="btn-plate"><div class="icon"><i class="fas fa-minus"></i></div><div class="label">Slab</div></div>
                </div>
            </div>
            
            <!-- Nature -->
            <div class="flex flex-col mb-2">
                <div class="category-label">Nature</div>
                <div class="flex flex-wrap">
                    <div class="block-btn" onclick="selectBlock('tree-oak')" id="btn-tree-oak"><div class="icon"><i class="fas fa-tree"></i></div><div class="label">Oak</div></div>
                    <div class="block-btn" onclick="selectBlock('tree-pine')" id="btn-tree-pine"><div class="icon"><i class="fas fa-tree" style="color: #0f5132;"></i></div><div class="label">Pine</div></div>
                    <div class="block-btn" onclick="selectBlock('rock')" id="btn-rock"><div class="icon"><i class="fas fa-mountain"></i></div><div class="label">Rock</div></div>
                    <div class="block-btn" onclick="selectBlock('bush')" id="btn-bush"><div class="icon"><i class="fas fa-leaf"></i></div><div class="label">Bush</div></div>
                </div>
            </div>
            
            <!-- Terrain -->
            <div class="flex flex-col mb-2">
                <div class="category-label">Terrain</div>
                <div class="flex flex-wrap">
                    <div class="block-btn" onclick="selectBlock('sand-block')" id="btn-sand-block"><div class="icon"><i class="fas fa-square" style="color: #f4e4bc;"></i></div><div class="label">Sand</div></div>
                    <div class="block-btn" onclick="selectBlock('sandstone-brick')" id="btn-sandstone-brick"><div class="icon"><i class="fas fa-square" style="color: #d4a574;"></i></div><div class="label">Stone</div></div>
                    <div class="block-btn" onclick="selectBlock('dirt')" id="btn-dirt"><div class="icon"><i class="fas fa-square" style="color: #5d4037;"></i></div><div class="label">Dirt</div></div>
                    <div class="block-btn" onclick="selectBlock('clay')" id="btn-clay"><div class="icon"><i class="fas fa-square" style="color: #b66a50;"></i></div><div class="label">Clay</div></div>
                </div>
            </div>
            
            <!-- Construction -->
